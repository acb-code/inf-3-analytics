# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# Upload limits
INF3_MAX_UPLOAD_SIZE_MB=2048

# App-level API key (defense-in-depth, optional but recommended)
# When set, all requests except /health must include X-API-Key header
INF3_API_KEY=

# Basic auth for inspect.lakesideai.dev (Caddy)
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
BASIC_AUTH_USER=tester
BASIC_AUTH_HASH=
